│   │   ├── nfe_parser.py         ← Parser XML NF-e
│   │   └── cep_cnpj.py           ← Consulta ViaCEP + BrasilAPI
│   ├── websocket/
│   │   └── manager.py
│   ├── static/                   ← Builds dos frontends
│   │   ├── admin/
│   │   ├── garcom/
│   │   ├── entregador/
│   │   └── producao/
│   └── data/
│       └── restaurante.db
│
├── frontend-admin/
├── pwa-garcom/
├── pwa-entregador/
├── tela-producao/
│
├── scripts/
│   ├── build-all.ps1             ← Compila todos os frontends + copia builds
│   └── gerar_licenca.py          ← Gerador de chaves RSA (uso futuro)
